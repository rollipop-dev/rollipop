{
  "name": "rollipop",
  "version": "1.0.0-alpha.24",
  "stableVersion": "1.0.0-alpha.23",
  "homepage": "https://github.com/rollipop-dev/rollipop#readme",
  "bugs": {
    "url": "https://github.com/rollipop-dev/rollipop/issues"
  },
  "license": "MIT",
  "author": "leegeunhyeok <dev.ghlee@gmail.com> (https://github.com/leegeunhyeok)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rollipop-dev/rollipop.git",
    "directory": "packages/rollipop"
  },
  "bin": "./bin/index.js",
  "files": [
    "client.d.ts",
    "bin",
    "dist",
    "skills",
    "src/runtime/**"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./commands": {
      "types": "./dist/commands.d.ts",
      "default": "./dist/commands.js"
    },
    "./filter": {
      "types": "./dist/filter.d.ts",
      "default": "./dist/filter.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "default": "./dist/runtime.js"
    },
    "./hmr-runtime": "./dist/hmr-runtime.iife.js",
    "./hmr-client": "./src/runtime/hmr-client.ts",
    "./client": {
      "types": "./client.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "prepack": "yarn build",
    "typecheck": "tsc --noEmit",
    "test": "vp test --run",
    "execute": "node bin/index.js",
    "build": "vp pack"
  },
  "dependencies": {
    "@babel/code-frame": "7.29.7",
    "@babel/core": "7.29.7",
    "@babel/plugin-transform-flow-strip-types": "7.29.7",
    "@babel/plugin-transform-typescript": "7.29.7",
    "@commander-js/extra-typings": "15.0.0",
    "@fastify/middie": "9.3.2",
    "@fastify/static": "9.1.3",
    "@inquirer/prompts": "8.5.2",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@node-rs/xxhash": "1.7.6",
    "@react-native-community/cli-server-api": "20.1.3",
    "@react-native-community/cli-types": "20.1.3",
    "@react-native/babel-plugin-codegen": "0.86.0",
    "@react-native/dev-middleware": "0.86.0",
    "@rollipop/dashboard": "workspace:*",
    "@rollipop/rolldown": "catalog:rolldown",
    "@swc/core": "1.15.41",
    "@swc/helpers": "0.5.23",
    "@types/ws": "8.18.1",
    "ajv": "8.20.0",
    "arktype": "2.2.0",
    "babel-plugin-syntax-hermes-parser": "0.36.1",
    "c12": "3.3.4",
    "chalk": "5.6.2",
    "commander": "15.0.0",
    "dayjs": "1.11.21",
    "dedent": "1.7.2",
    "dotenv": "17.4.2",
    "dotenv-expand": "13.0.0",
    "es-toolkit": "catalog:",
    "fast-flow-transform": "0.0.3",
    "fastify": "5.8.5",
    "fastify-plugin": "6.0.0",
    "gradient-string": "3.0.0",
    "image-size": "2.0.2",
    "json-schema-to-ts": "3.1.1",
    "mime": "4.1.0",
    "mitt": "3.0.1",
    "open": "11.0.0",
    "rolldown-analyzer": "0.3.0",
    "source-map": "0.7.6",
    "strip-ansi": "7.2.0",
    "url": "0.11.4",
    "wrap-ansi": "10.0.0",
    "ws": "8.21.0"
  },
  "devDependencies": {
    "@types/babel__code-frame": "7.27.0",
    "@types/babel__core": "7.20.5",
    "magic-string": "0.30.21",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
