{
  "name": "rollipop",
  "version": "1.0.0-alpha.21",
  "homepage": "https://github.com/leegeunhyeok/rollipop#readme",
  "bugs": {
    "url": "https://github.com/leegeunhyeok/rollipop/issues"
  },
  "license": "MIT",
  "author": "leegeunhyeok <dev.ghlee@gmail.com> (https://github.com/leegeunhyeok)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leegeunhyeok/rollipop.git",
    "directory": "packages/rollipop"
  },
  "bin": "./bin/index.js",
  "files": [
    "client.d.ts",
    "bin",
    "dist",
    "src/runtime/**"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./commands": {
      "import": {
        "types": "./dist/commands.d.ts",
        "default": "./dist/commands.js"
      },
      "require": {
        "types": "./dist/commands.d.cts",
        "default": "./dist/commands.cjs"
      }
    },
    "./pluginutils": {
      "types": "./dist/pluginutils.d.ts",
      "default": "./dist/pluginutils.js"
    },
    "./runtime": {
      "import": {
        "types": "./dist/runtime.d.ts",
        "default": "./dist/runtime.js"
      },
      "require": {
        "types": "./dist/runtime.d.cts",
        "default": "./dist/runtime.cjs"
      }
    },
    "./hmr-runtime": "./dist/hmr-runtime.iife.js",
    "./hmr-client": "./src/runtime/hmr-client.ts",
    "./client": {
      "types": "./client.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "prepack": "yarn build",
    "typecheck": "tsc --noEmit",
    "test": "vp test --run",
    "execute": "node bin/index.js",
    "build": "vp pack"
  },
  "dependencies": {
    "@babel/code-frame": "^7.29.0",
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-flow-strip-types": "^7.27.1",
    "@babel/plugin-transform-typescript": "^7.28.6",
    "@commander-js/extra-typings": "^14.0.0",
    "@fastify/middie": "^9.3.1",
    "@inquirer/prompts": "^8.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@node-rs/xxhash": "^1.7.6",
    "@react-native-community/cli-server-api": "^20.1.2",
    "@react-native-community/cli-types": "^20.1.2",
    "@react-native/babel-plugin-codegen": "^0.84.1",
    "@react-native/dev-middleware": "^0.84.1",
    "@rollipop/rolldown": "catalog:rolldown",
    "@rollipop/rolldown-pluginutils": "catalog:rolldown",
    "@swc/core": "^1.15.18",
    "@swc/helpers": "^0.5.19",
    "@types/ws": "^8",
    "ajv": "^8.18.0",
    "babel-plugin-syntax-hermes-parser": "^0.33.3",
    "c12": "^3.3.3",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dayjs": "^1.11.19",
    "dedent": "^1.7.2",
    "dotenv": "^17.3.1",
    "dotenv-expand": "^12.0.3",
    "es-toolkit": "^1.45.1",
    "fast-flow-transform": "^0.0.3",
    "fastify": "^5.8.1",
    "fastify-plugin": "^5.1.0",
    "gradient-string": "^3.0.0",
    "image-size": "^2.0.2",
    "json-schema-to-ts": "^3.1.1",
    "mime": "^4.1.0",
    "mitt": "^3.0.1",
    "p-limit": "^7.3.0",
    "source-map": "^0.7.6",
    "strip-ansi": "^7.2.0",
    "url": "^0.11.4",
    "wrap-ansi": "^10.0.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/babel__code-frame": "^7",
    "@types/babel__core": "^7",
    "@types/babel__generator": "^7",
    "magic-string": "^0.30.21",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  }
}
