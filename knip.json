{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreExportsUsedInFile": true,
  "tags": ["-lintignore"],
  "ignoreIssues": {
    "examples/module-federation/src/host/App.tsx": ["unlisted"],
    "examples/0.72/hmr-client.ts": ["unresolved"],
    "packages/rollipop/src/runtime/hmr-client.ts": ["unresolved"],
    "packages/rollipop/src/internal/react-native.ts": ["unlisted"],
    "packages/plugin-rozenite/src/patch.ts": ["unlisted"]
  },
  "workspaces": {
    ".": {
      "entry": ["vite.config.ts"]
    },
    "docs": {
      "entry": [
        "source.config.ts",
        "src/app/**/*.{ts,tsx}",
        "src/mdx-components.tsx",
        "src/components/mdx/**/*.{ts,tsx}",
        "scripts/**/*.mjs"
      ],
      "project": ["**/*.{js,mjs,ts,tsx}", "!**/.next/**", "!**/.source/**", "!out/**"],
      "ignoreDependencies": ["tailwindcss"]
    },
    "examples/0.72": {
      "entry": ["App.tsx", "rollipop.config.ts", "__tests__/**/*.{js,jsx,ts,tsx}", "hmr-client.ts"],
      "project": ["**/*.{js,jsx,ts,tsx,mjs,mts,cjs,cts}", "!android/**", "!ios/**"],
      "ignoreDependencies": ["@babel/runtime", "babel-jest"]
    },
    "examples/0.84": {
      "entry": ["App.tsx", "rollipop.config.ts", "__tests__/**/*.{js,jsx,ts,tsx}"],
      "project": ["**/*.{js,jsx,ts,tsx,mjs,mts,cjs,cts}", "!android/**", "!ios/**"],
      "ignoreDependencies": ["@babel/runtime", "@swc/helpers"]
    },
    "examples/module-federation": {
      "entry": [
        "rollipop.host.config.ts",
        "rollipop.remote.config.ts",
        "mf-script-loader.ts",
        "native/**/*.{ts,tsx}",
        "src/host/index.ts",
        "src/remote/index.ts",
        "src/remote/exposed/**/*.{ts,tsx}"
      ],
      "project": ["**/*.{js,jsx,ts,tsx,mjs,mts,cjs,cts}", "!android/**", "!ios/**"],
      "ignoreDependencies": ["@babel/runtime", "@module-federation/runtime"]
    },
    "packages/dashboard": {
      "project": ["src/**/*.{js,jsx,ts,tsx}"],
      "ignoreDependencies": ["shadcn", "tailwindcss", "tw-animate-css"]
    },
    "packages/init": {
      "entry": ["vite.config.ts", "src/**/__tests__/**/*.{js,jsx,ts,tsx}"],
      "project": ["**/*.{js,jsx,ts,tsx,mjs,mts,cjs,cts}", "!dist/**"]
    },
    "packages/jest-preset": {
      "entry": ["vite.config.ts", "src/index.ts", "src/transformer.ts", "src/mock.ts"],
      "project": ["**/*.{js,jsx,ts,tsx,mjs,mts,cjs,cts}", "!dist/**"]
    },
    "packages/plugin-module-federation": {
      "entry": [
        "vite.config.ts",
        "src/index.ts",
        "src/runtime.ts",
        "src/**/__tests__/**/*.{js,jsx,ts,tsx}"
      ],
      "project": ["**/*.{js,jsx,ts,tsx,mjs,mts,cjs,cts}", "!dist/**"],
      "ignoreDependencies": ["@module-federation/runtime"]
    },
    "packages/plugin-rozenite": {
      "entry": ["vite.config.ts", "src/index.ts"],
      "project": ["**/*.{js,jsx,ts,tsx,mjs,mts,cjs,cts}", "!dist/**"]
    },
    "packages/plugin-svg": {
      "entry": ["vite.config.ts", "src/index.ts"],
      "project": ["**/*.{js,jsx,ts,tsx,mjs,mts,cjs,cts}", "!dist/**"]
    },
    "packages/rollipop": {
      "entry": [
        "vite.config.ts",
        "src/index.ts",
        "src/commands.ts",
        "src/filter.ts",
        "src/runtime.ts",
        "src/runtime/hmr-runtime.ts",
        "bin/**/*.js",
        "src/**/__tests__/**/*.{js,jsx,ts,tsx}",
        "e2e/**/*.spec.ts",
        "e2e/helpers.ts",
        "e2e/runtime/harness.ts",
        "testing/**/*.{js,jsx,ts,tsx}"
      ],
      "project": ["**/*.{js,jsx,ts,tsx,mjs,mts,cjs,cts}", "!dist/**"],
      "ignoreFiles": ["e2e/**/__fixtures__/**"]
    }
  }
}
